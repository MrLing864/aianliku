  "businessFunctions": [],
  "summary": "中国移动研究院携手江苏移动公司，针对无线网络优化长期痛点，研发基于“九天·网络大模型”的 AI+无线网络自闭环优化应用，将大模型能力用于无线信号传播等复杂场景，重构网络优化模式，推动自智网络升级。",
  "background": "中国移动“九天”人工智能平台提供从智算基础设施、核心算法到智能化应用的全栈服务，全面支持自智网络等多样场景。",
  "problem": "传统无线网络优化依靠人员现场勘察、人工取数分析与专家逐站比选，效率低、周期长、难以全局寻优。",
  "solution": "基于九天·网络大模型的 AI+无线网络自闭环优化应用，将生成式 AI 用于无线信号传播复杂场景，实现网络优化模式重构。",
  "implementationSteps": [
    "依托九天平台构建网络大模型",
    "研发 AI+无线网络自闭环优化应用",
    "在江苏移动等现网落地应用"
  ],
