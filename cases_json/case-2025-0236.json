  "businessFunctions": [],
  "summary": "国网甘肃省电力公司“电力应急响应指挥小助手应用”入选工信部 2025 年人工智能应用典型案例。近年来国网甘肃省电力公司持续推进应急管理数字化，健全应急指挥体系与应急基干队伍，配置应急指挥车、通信车、移动电源车等大型应急装备，并以人工智能赋能应急响应指挥，提升防灾减灾救灾与突发事件处置能力。",
  "background": "",
  "problem": "电力突发事件应急响应涉及信息多、决策快，传统指挥依赖人工调度，效率与协同有待提升。",
  "solution": "以 AI 打造电力应急响应指挥“小助手”，辅助应急信息汇聚、研判与指挥调度，提升应急响应效率与协同水平。",
  "implementationSteps": [
    "汇聚应急管理与电网运行数据",
    "以 AI 辅助应急研判与指挥调度",
    "打造电力应急响应指挥小助手",
    "在电力应急指挥场景应用"
  ],
