  "businessFunctions": [],
  "summary": "湖南华菱湘潭钢铁联合华为研发钢铁行业专用AI平台（基于盘古大模型+华为云Stack混合云），其中精炼AI预测与优化系统实现合金成分与温度精准控制，预期命中率超95%，年节省原辅材料及能耗成本超200万元，并获国际电信联盟人工智能优秀创新案例奖。",
  "background": "钢铁精炼环节对合金成分与温度控制要求极高，依赖老师傅经验，波动大。",
  "problem": "精炼优化依赖人工经验，成分与温度预测不准，成本高、稳定性差。",
  "solution": "湘钢与华为联合研发全球首个钢铁行业大模型（基于盘古大模型架构、华为云Stack混合云），构建精炼AI预测与优化系统，使工程师可快速精准控制预测炼钢合金成分和温度；该应用获2024年6月国际电信联盟（ITU）人工智能优秀创新案例奖。",
  "implementationSteps": [
    "联合华为构建钢铁行业专用AI平台",
    "研发精炼AI预测与优化系统",
    "实现合金成分与温度精准控制",
    "获ITU人工智能优秀创新案例奖并推广"
  ],
