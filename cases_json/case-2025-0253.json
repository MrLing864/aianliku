  "businessFunctions": [],
  "summary": "沪渝人工智能研究院（上海交通大学重庆人工智能研究院）研发“医疗全景智能体”，依托海量医疗专业数据与知识库及先进多模态大模型技术，可 1 分钟精准“画”出病灶准确位置，并在某县域医共体成功落地，通过为基层医疗机构提供专业 AI 支撑弥补当地医疗短板，同时衍生“青囊 AI”服务基层医药场景。",
  "background": "沪渝人工智能研究院依托上海交通大学科研力量，在西部（重庆）科学城打造人工智能创新平台，聚焦智慧医疗领域跨模态、跨中心、小样本、可解释的人工智能模型与算法。",
  "problem": "基层医疗机构优质医疗资源匮乏，影像与诊断能力不足，难以满足常见病精准诊疗需求。",
  "solution": "医疗全景智能体以多模态大模型技术，实现病灶精准定位与辅助诊疗，下沉县域医共体弥补基层短板。",
  "implementationSteps": [
    "构建医疗专业数据与知识库",
    "研发多模态大模型医疗全景智能体",
    "在县域医共体落地应用"
  ],
