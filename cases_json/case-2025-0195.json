  "businessFunctions": [],
  "summary": "深圳供电局（南方电网深圳宝安供电局）10kV 配网带电作业智能机器人应用入选工信部 2025 年人工智能应用典型案例。该配网带电作业机器人搭载双机械臂，融合仿真建模、视觉识别及运动控制三大核心技术，可高效完成带电拆火接火等作业，2025 年 3 月完成深圳全市首单配网机器人带电作业。",
  "background": "配网带电作业高危，对机器人替代需求强。",
  "problem": "10kV 配网带电作业风险高、依赖人工登高操作，安全与效率难以兼顾。",
  "solution": "研发配网带电作业智能机器人，以双机械臂+仿真建模+视觉识别+运动控制实现带电作业自动化，减少人工登高风险。",
  "implementationSteps": [
    "研制搭载双机械臂的配网带电作业机器人",
    "融合仿真建模、视觉识别与运动控制",
    "地面技术人员配合机器人协同作业",
    "在配电网带电拆接火等场景落地应用"
  ],
