# CloudBase 文档型数据库（替代 MongoDB / MongoDB Atlas）
# 控制台获取：环境 ID、密钥对（SecretId / SecretKey）
CLOUDBASE_ENV=your-cloudbase-env-id
CLOUDBASE_SECRET_ID=your-secret-id
CLOUDBASE_SECRET_KEY=your-secret-key

# Auth.js single administrator
AUTH_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-argon2id-hash-from-npm-run-admin-hash

# DeepSeek direct API (server only)
DEEPSEEK_API_KEY=replace-with-deepseek-key
AI_MODEL=deepseek-v4-pro
AI_FAST_MODEL=deepseek-v4-flash

# Public base URL
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional private source snapshots (EdgeOne Makers Blob)
# 免费版单账户 1GB，取代收费的腾讯云 COS。部署为 Makers 项目时平台自动注入凭据，
# 此处可留空；部署为普通 EdgeOne Pages（非 Makers 运行时）时需显式提供。
# 参考：https://cloud.tencent.com/document/product/1552/131425
EO_BLOB_PROJECT_ID=
EO_BLOB_TOKEN=
EO_BLOB_STORE=aianliku

# Optional production operations alert webhook (payloads never include user input)
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_BEARER_TOKEN=
