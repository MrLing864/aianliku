      }
    ],
    "roi": "",
    "risks": "工业现场对非结构化任务的可靠性、安全认证与规模化运维仍需验证；人形机器人单位成本高，投资回收周期待评估。",
    "editorComment": {
      "suitableFor": "多品种小批量、物料流转频繁的离散制造场景",
      "prerequisites": "需具备机器人调度与产线接口能力",
